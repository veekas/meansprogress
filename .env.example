# Copy this to .env for local development.
# Set the same variables in your Netlify dashboard under Site Settings → Environment variables.

# ── Local mock mode (optional) ───────────────────────────────────────
# When DEV_MOCK=1, npm run dev uses an in-memory database and skips Supabase.
# Login still shows the OTP step — use code 000000. Any phone number works;
# ADMIN_PHONE still gets /admin. No Supabase credentials required.
# DEV_MOCK=1

# ── Supabase ─────────────────────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API
PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — NEVER expose this on the client. Server-only.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Admin access ─────────────────────────────────────────────────────
# Your phone number in E.164 format. This account gets access to /admin.
ADMIN_PHONE=+15551234567

# ── Signal notifications (CallMeBot) ─────────────────────────────────
# One-time setup: send "I allow callmebot to send me messages" to +34 644 52 74 88 on Signal.
# They reply with your API key. Notifications go to ADMIN_PHONE.
# Without this, Signal notifications are skipped.
# CALLMEBOT_SIGNAL_KEY=your-api-key-here

# ── WhatsApp notifications (CallMeBot) ───────────────────────────────
# One-time setup: https://www.callmebot.com/blog/free-api-whatsapp-messages/
# Add their contact, send "I allow callmebot to send me messages" via WhatsApp.
# They reply with your API key. Notifications go to ADMIN_PHONE.
# Without this, WhatsApp notifications are skipped.
CALLMEBOT_WHATSAPP_KEY=your-api-key-here

# ── Email notifications (Resend) ──────────────────────────────────────
# Without these, access requests and feedback still save — you just won't get emailed.
RESEND_API_KEY=re_xxxxxxxx
ACCESS_REQUEST_NOTIFY_EMAIL=you@example.com
# RESEND_FROM_EMAIL= # Sender address. Default is onboarding@resend.dev
