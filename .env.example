# Copy this to .env for local development.
# Set the same variables in your Netlify dashboard under Site Settings → Environment variables.

# ── Supabase ─────────────────────────────────────────────────────────
# Found in: Supabase dashboard → Project Settings → API
PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key — NEVER expose this on the client. Server-only.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Admin access ─────────────────────────────────────────────────────
# Your phone number in E.164 format. This account gets access to /admin.
# Must also be in the whitelist table.
ADMIN_PHONE=+15551234567
